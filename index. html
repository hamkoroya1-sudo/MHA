<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MHA STORE // UNDERGROUND STREETWEAR</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Tajawal:wght@500;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-black: #050505;
    --neon-green: #00ff66;
    --dark-surface: #0d0d0d;
    --border-color: #222222;
    --text-muted: #777777;
    --text-main: #ffffff;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background-color: var(--bg-black);
    color: var(--text-main);
    font-family: 'Tajawal', sans-serif;
    overflow-x: hidden;
    selection-background-color: var(--neon-green);
    selection-color: var(--bg-black);
  }

  /* Glitch Text Effect for Brand Identity */
  .glitch-text {
    font-family: 'Syncopate', sans-serif;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
  }

  /* Neo-Brutalism Header */
  header {
    border-bottom: 2px solid var(--border-color);
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    background: rgba(5,5,5,0.9);
    backdrop-filter: blur(10px);
    z-index: 1000;
  }
  .logo {
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: -1px;
    color: var(--text-main);
    text-decoration: none;
  }
  .logo span { color: var(--neon-green); }
  
  .nav-menu { display: flex; gap: 30px; list-style: none; }
  .nav-menu a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9.5rem;
    font-weight: 800;
    transition: color 0.3s;
  }
  .nav-menu a:hover, .nav-menu .active { color: var(--neon-green); }

  .cart-btn {
    background: transparent;
    border: 2px solid var(--neon-green);
    color: var(--neon-green);
    padding: 8px 18px;
    font-weight: 800;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .cart-btn:hover {
    background: var(--neon-green);
    color: var(--bg-black);
    box-shadow: 0 0 15px rgba(0, 255, 102, 0.4);
  }

  /* Hero Section Radical Change */
  .hero-section {
    min-height: 85vh;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    border-bottom: 2px solid var(--border-color);
  }
  .hero-left {
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 2px solid var(--border-color);
  }
  .hero-tag {
    color: var(--neon-green);
    font-weight: 900;
    font-size: 0.9rem;
    letter-spacing: 2px;
    margin-bottom: 15px;
    text-transform: uppercase;
  }
  .hero-main-title {
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 25px;
    letter-spacing: -2px;
  }
  .hero-main-title em {
    font-style: normal;
    -webkit-text-stroke: 1px var(--text-main);
    color: transparent;
  }
  .hero-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 550px;
    line-height: 1.7;
    margin-bottom: 40px;
  }
  .cta-group { display: flex; gap: 20px; }
  .btn-bold {
    background: var(--text-main);
    color: var(--bg-black);
    padding: 18px 36px;
    font-weight: 900;
    text-decoration: none;
    font-size: 1rem;
    text-transform: uppercase;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-bold:hover {
    transform: translate(-4px, -4px);
    box-shadow: 4px 4px 0px var(--neon-green);
  }
  
  .hero-right {
    background: linear-gradient(45deg, #0a0a0a, #151515);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .hero-graphic {
    font-size: 11rem;
    filter: drop-shadow(0 0 30px rgba(255,255,255,0.05));
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  /* Infinite Giant Ticker / Marquee */
  .giant-ticker {
    background: var(--neon-green);
    color: var(--bg-black);
    padding: 25px 0;
    overflow: hidden;
    display: flex;
    border-bottom: 2px solid var(--border-color);
  }
  .ticker-wrap {
    display: flex;
    white-space: nowrap;
    animation: tickerMove 25s linear infinite;
  }
  .ticker-wrap span {
    font-family: 'Syncopate', sans-serif;
    font-size: 2.2rem;
    font-weight: 900;
    padding: 0 30px;
  }
  @keyframes tickerMove {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Brutalist Products Grid */
  .catalog-section { padding: 80px 40px; }
  .catalog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 50px;
  }
  .section-headline { font-size: 2.5rem; font-weight: 900; letter-spacing: -1px; }
  .section-headline span { color: var(--neon-green); }
  
  .grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px;
  }
  
  .brutal-card {
    background: var(--dark-surface);
    border: 2px solid var(--border-color);
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .brutal-card:hover {
    border-color: var(--neon-green);
    transform: scale(1.02);
  }
  .card-img-box {
    aspect-ratio: 1;
    background: #121212;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5.5rem;
    border-bottom: 2px solid var(--border-color);
    position: relative;
  }
  .card-badge {
    position: absolute;
    top: 15px; left: 15px;
    background: var(--neon-green);
    color: var(--bg-black);
    font-size: 0.75rem;
    font-weight: 900;
    padding: 4px 10px;
  }
  .card-details { padding: 20px; }
  .card-meta { color: var(--text-muted); font-size: 0.8rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px;}
  .card-title { font-size: 1.15rem; font-weight: 900; margin-bottom: 15px; }
  
  .card-footer-action {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .price-tag { font-size: 1.3rem; font-weight: 900; color: var(--neon-green); }
  .buy-btn-icon {
    background: var(--text-main);
    color: var(--bg-black);
    border: none;
    width: 40px; height: 40px;
    font-size: 1.2rem;
    font-weight: 900;
    cursor: pointer;
    transition: background 0.2s;
  }
  .brutal-card:hover .buy-btn-icon { background: var(--neon-green); }

  /* Concept Showcase Section */
  .lookbook-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 2px solid var(--border-color);
    border-bottom: 2px solid var(--border-color);
  }
  .lookbook-box { padding: 80px 40px; display: flex; flex-direction: column; justify-content: center;}
  .lookbook-box.visual {
    background: #111;
    font-size: 9rem;
    text-align: center;
    border-right: 2px solid var(--border-color);
  }

  /* Foot System */
  footer { padding: 60px 40px; border-top: 2px solid var(--border-color); background: #020202; }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr repeat(2, 1fr);
    gap: 40px;
    margin-bottom: 50px;
  }
  .footer-logo { font-size: 2rem; font-weight: 900; margin-bottom: 15px; }
  .footer-about { color: var(--text-muted); max-width: 400px; line-height: 1.6; }
  .footer-title { font-size: 1rem; font-weight: 900; color: var(--text-main); margin-bottom: 20px; text-transform: uppercase; }
  .footer-links { list-style: none; }
  .footer-links li { margin-bottom: 10px; }
  .footer-links a { color: var(--text-muted); text-decoration: none; transition: color 0.2s; font-weight: 500; }
  .footer-links a:hover { color: var(--neon-green); }
  
  .footer-copyright {
    border-top: 1px solid var(--border-color);
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Responsive Fixes */
  @media(max-width: 768px) {
    .hero-section, .lookbook-section { grid-template-columns: 1fr; }
    .hero-right { padding: 60px 0; border-top: 2px solid var(--border-color); }
    .nav-menu { display: none; }
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- Header -->
<header>
