<script>
// Cursor
const cursor = document.getElementById('cursor');
const follower = document.getElementById('follower');
let mx=0,my=0,fx=0,fy=0;
document.addEventListener('mousemove', e=>{
  mx=e.clientX; my=e.clientY;
  cursor.style.left=mx-6+'px';
  cursor.style.top=my-6+'px';
});
setInterval(()=>{
  fx+=(mx-fx)*0.12; fy+=(my-fy)*0.12;
  follower.style.left=fx-18+'px';
  follower.style.top=fy-18+'px';
},16);
document.querySelectorAll('button,a,.product-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>{ cursor.style.transform='scale(2)'; follower.style.transform='scale(1.5)'; });
  el.addEventListener('mouseleave',()=>{ cursor.style.transform='scale(1)'; follower.style.transform='scale(1)'; });
});

// Loader
window.addEventListener('load',()=>{
  setTimeout(()=>{ document.getElementById('loader').classList.add('hidden'); },2200);
});

// Nav scroll
window.addEventListener('scroll',()=>{
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY>80);
});

// Particles
const container = document.getElementById('particles');
for(let i=0;i<30;i++){
  const p = document.createElement('div');
  p.className='particle';
  p.style.cssText=`left:${Math.random()*100}%;--dur:${6+Math.random()*10}s;--delay:${Math.random()*8}s;--drift:${(Math.random()-0.5)*100}px`;
  container.appendChild(p);
}

// Scroll reveal
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

// Counter animation
const countObserver = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const el=e.target;
      const target=+el.dataset.target;
      const dur=2000; const step=dur/60;
      let current=0;
      const t=setInterval(()=>{
        current+=target/60;
        if(current>=target){ el.textContent=target.toLocaleString('ar'); clearInterval(t); }
        else el.textContent=Math.floor(current).toLocaleString('ar');
      },step);
      countObserver.unobserve(el);
    }
  });
},{threshold:0.5});
document.querySelectorAll('[data-target]').forEach(el=>countObserver.observe(el));
</script>
