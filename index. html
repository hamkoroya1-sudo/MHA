<script>
  let totalItems = 0;
  function updateCart(name) {
    totalItems++;
    document.getElementById('cart-counter').textContent = `BAG [${totalItems}]`;
    alert(`تمت إضافة [${name}] لملفات طلباتك الحالية.`);
  }
</script>
</body>
</html>
